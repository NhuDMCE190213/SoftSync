@inherits LayoutComponentBase

<div class="page">
    <nav class="ss-nav py-3 px-4 d-flex justify-content-between align-items-center">
        <div class="d-flex align-items-center gap-2 cursor-pointer" onclick="window.location.href='/'">
            <div style="width: 40px; height: 40px; background: var(--gradient); border-radius: 10px; overflow: hidden;" class="d-flex align-items-center justify-content-center">
                <img src="images/logo.png" alt="S" class="w-100 h-100 object-fit-cover" />
            </div>
            <span class="fs-4 fw-bold ss-gradient-text">SoftSync</span>
        </div>

        <div class="d-flex gap-4 align-items-center">
            <a href="/" class="text-decoration-none text-dark fw-medium nav-link-hover">Home</a>
            <a href="/roadmap" class="text-decoration-none text-dark fw-medium nav-link-hover">Road Map</a>
            <a href="/assistant" class="text-decoration-none text-dark fw-medium nav-link-hover">AI Assistant</a>
            <a href="/case-studies" class="text-decoration-none text-dark fw-medium nav-link-hover">Case Studies</a>
            <a href="/progress" class="text-decoration-none text-dark fw-medium nav-link-hover">Progress</a>
            <a href="/community" class="text-decoration-none text-dark fw-medium nav-link-hover">Community</a>

            <AuthorizeView>
                <Authorized>
                    <div class="account-menu" @onclick="ToggleMenu">
                        <button class="btn ss-btn-outline d-flex align-items-center gap-2" type="button">
                            <i class="bi bi-person-circle fs-5"></i>
                            <span>@context.User.Identity?.Name</span>
                            <i class="bi bi-chevron-down small"></i>
                        </button>

                        @if (showMenu)
                        {
                            <ul class="account-dropdown shadow">
                                <li><a class="dropdown-item" href="/profile"><i class="bi bi-person-lines-fill me-2"></i>Hồ sơ của tôi</a></li>
                                <li><a class="dropdown-item" href="/change-password"><i class="bi bi-key-fill me-2"></i>Đổi mật khẩu</a></li>
                                <li><hr class="dropdown-divider" /></li>
                                <li>
                                    <form method="post" action="/api/auth/logout">
                                        <button type="submit" class="dropdown-item text-danger border-0 bg-transparent w-100 text-start">
                                            <i class="bi bi-box-arrow-right me-2"></i>Đăng xuất
                                        </button>
                                    </form>
                                </li>
                            </ul>
                        }
                    </div>
                </Authorized>
                <NotAuthorized>
                    <a href="/login" class="text-decoration-none text-dark fw-medium nav-link-hover">Đăng nhập</a>
                    <a href="/register" class="ss-btn-primary px-3 py-2">Đăng ký</a>
                </NotAuthorized>
            </AuthorizeView>
        </div>
    </nav>

    <main class="container py-5">
        @Body
    </main>
</div>

<style>
    .nav-link-hover {
        transition: color 0.2s;
    }

        .nav-link-hover:hover {
            color: var(--primary) !important;
        }

    .cursor-pointer {
        cursor: pointer;
    }

    .account-menu {
        position: relative;
    }

    .account-dropdown {
        position: absolute;
        right: 0;
        top: 115%;
        min-width: 210px;
        background: #fff;
        border-radius: 12px;
        padding: 0.5rem 0;
        list-style: none;
        z-index: 1000;
    }

        .account-dropdown .dropdown-item {
            padding: 0.5rem 1rem;
            display: block;
            color: #212529;
            text-decoration: none;
            font-size: 0.9rem;
            cursor: pointer;
        }

            .account-dropdown .dropdown-item:hover {
                background: var(--gradient-soft);
            }
</style>

<div id="blazor-error-ui">
    An unhandled error has occurred.
    <a href="" class="reload">Reload</a>
    <a class="dismiss">🗙</a>
</div>

@code {
    private bool showMenu = false;
    private void ToggleMenu() => showMenu = !showMenu;
}