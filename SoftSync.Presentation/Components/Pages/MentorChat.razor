@page "/community/chat/{MentorId:int}"
@using SoftSync.BLL.Interfaces
@using SoftSync.Presentation.Infrastructure
@inject IMentorChatService MentorChatService
@inject CurrentUserAccessor CurrentUserAccessor
@attribute [Authorize]
@implements IDisposable

<div class="max-800 mx-auto">
    <h4 class="fw-bold mb-4">Chat với Mentor</h4>
    <div class="ss-card p-3 mb-3" style="height:400px; overflow-y:auto;">
        @if (messages != null)
        {
            @foreach (var m in messages)
            {
                <div class="mb-2 @(m.SenderType == "User" ? "text-end" : "text-start")">
                    <span class="badge @(m.SenderType == "User" ? "bg-primary" : "bg-secondary")">@m.Content</span>
                </div>
            }
        }
    </div>
    <div class="d-flex gap-2">
        <input class="form-control" @bind="draft" @bind:event="oninput" placeholder="Nhập tin nhắn..." />
        <button class="btn btn-primary" @onclick="Send">Gửi</button>
    </div>
</div>

@code {
    [Parameter] public int MentorId { get; set; }
    private int userId;
    private string draft = "";
    private List<(string SenderType, string Content, DateTime CreatedAt)>? messages;
    private System.Threading.Timer? _timer;

    protected override async Task OnInitializedAsync()
    {
        userId = (await CurrentUserAccessor.GetUserIdAsync()) ?? 0;
        await Load();
        _timer = new System.Threading.Timer(async _ => await InvokeAsync(Load), null, 3000, 3000); // MVP: polling
    }

    private async Task Load()
    {
        messages = await MentorChatService.GetConversationAsync(userId, MentorId);
        await InvokeAsync(StateHasChanged);
    }

    private async Task Send()
    {
        if (string.IsNullOrWhiteSpace(draft)) return;
        await MentorChatService.SendMessageAsync(userId, MentorId, draft);
        draft = "";
        await Load();
    }

    public void Dispose() => _timer?.Dispose();
}

<style>
    .max-800 {
        max-width: 800px;
    }
</style>