@page "/community/chat/{MentorId:int}"
@using SoftSync.BLL.Interfaces
@using SoftSync.Common.Dtos
@using SoftSync.Presentation.Infrastructure
@inject IMentorChatService MentorChatService
@inject IMentorService MentorService
@inject CurrentUserAccessor CurrentUserAccessor
@attribute [Authorize]
@implements IDisposable

<div class="max-800 mx-auto h-100 d-flex flex-column" style="min-height: 70vh;">

    <div class="mb-4 d-flex align-items-center gap-3">
        <a href="/community" class="text-muted" title="Quay lại danh sách mentor">
            <i class="bi bi-arrow-left fs-4"></i>
        </a>

        @if (mentor != null)
        {
            <img src="@mentor.AvatarUrl" class="rounded-circle" style="width:52px;height:52px;object-fit:cover;" />
            <div>
                <h2 class="fw-bold mb-0"><span class="ss-gradient-text">@mentor.Name</span></h2>
                <p class="text-muted mb-0">@mentor.Expertise</p>
            </div>
        }
        else
        {
            <h2 class="fw-bold mb-1">Chat với Mentor</h2>
        }
    </div>

    <div class="ss-card flex-grow-1 p-4 mb-4 overflow-auto d-flex flex-column" style="max-height: 550px;">
        @if (messages == null)
        {
            <div class="text-center text-muted m-auto">Đang tải cuộc trò chuyện...</div>
        }
        else if (messages.Count == 0)
        {
            <div class="text-center text-muted m-auto">
                <i class="bi bi-chat-heart fs-1 d-block mb-2"></i>
                Hãy gửi lời chào để bắt đầu trò chuyện với @(mentor?.Name ?? "mentor") nhé!
            </div>
        }
        else
        {
            foreach (var m in messages)
            {
                bool isUser = m.SenderType == "User";
                <div class="chat-bubble chat-bubble-lg @(isUser ? "chat-user" : "chat-assistant")">
                    @m.Content
                    <div class="chat-bubble-time">@m.CreatedAt.ToString("HH:mm")</div>
                </div>
            }
        }

        @if (isSending)
        {
            <div class="chat-bubble chat-bubble-lg chat-assistant text-muted">
                <span class="spinner-grow spinner-grow-sm"></span> Đang trả lời...
            </div>
        }
    </div>

    <div class="input-group">
        <input type="text" class="form-control form-control-lg p-3" placeholder="Nhập tin nhắn..."
               @bind="draft" @bind:event="oninput" @onkeydown="OnKeyDown" disabled="@isSending" />
        <button class="ss-btn-primary px-4" @onclick="Send" disabled="@(isSending || string.IsNullOrWhiteSpace(draft))">
            <i class="bi bi-send-fill"></i>
        </button>
    </div>
</div>

<style>
    .max-800 {
        max-width: 800px;
    }

    .overflow-auto {
        overflow-y: auto;
    }

    /* Bigger speech bubbles for mentor chat */
    .chat-bubble-lg {
        font-size: 1.05rem;
        padding: 1rem 1.4rem;
        max-width: 80%;
        border-radius: 1.4rem;
    }

    .chat-bubble-time {
        font-size: 0.7rem;
        opacity: 0.7;
        margin-top: 0.35rem;
    }
</style>

@code {
    [Parameter] public int MentorId { get; set; }

    private int userId;
    private string draft = "";
    private MentorDto? mentor;
    private List<(string SenderType, string Content, DateTime CreatedAt)>? messages;
    private System.Threading.Timer? _timer;
    private bool isSending = false;

    protected override async Task OnInitializedAsync()
    {
        userId = (await CurrentUserAccessor.GetUserIdAsync()) ?? 0;
        mentor = await MentorService.GetByIdAsync(MentorId);
        await Load();
        _timer = new System.Threading.Timer(async _ => await InvokeAsync(Load), null, 3000, 3000); // MVP: polling
    }

    private async Task Load()
    {
        messages = await MentorChatService.GetConversationAsync(userId, MentorId);
        await InvokeAsync(StateHasChanged);
    }

    private async Task OnKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !isSending && !string.IsNullOrWhiteSpace(draft))
        {
            await Send();
        }
    }

    private async Task Send()
    {
        if (string.IsNullOrWhiteSpace(draft) || isSending) return;

        var content = draft;
        draft = "";
        isSending = true;
        StateHasChanged();

        try
        {
            await MentorChatService.SendMessageAsync(userId, MentorId, content);
            await Load();
        }
        finally
        {
            isSending = false;
        }
    }

    public void Dispose() => _timer?.Dispose();
}
