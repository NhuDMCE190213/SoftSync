    private enum Tab { Account, Learning, Notifications, Appearance, Privacy, Danger }
    private Tab tab = Tab.Account;

    private const long MaxAvatarBytes = 3 * 1024 * 1024;
    private UserDto? user;
    private int userId;
    private string? email;
    private string? phone;
    private string langCode = "en";

    private IEnumerable<SkillDto>? skills;
    private readonly List<int> selectedSkillIds = new();

    // Hero stats
    private int dayStreak;
    private int badgeCount;

    // Notification / privacy toggles — UI-only for now (no persisted preference model yet).
    private bool notifStudy = true;
    private bool notifProgress = true;
    private bool notifCommunity;
    private bool publicProfile = true;
    private bool showOnLeaderboard = true;

    // Linked account rows for the mockup grid.
    private record LinkedProvider(string Scheme, string Name, string Icon, string Bg, string Fg, bool Available, bool Connected);
    private List<LinkedProvider> linkedProviders = new();

    // Preset goals stored as translation keys (same set as the onboarding wizard),
    // so the saved value stays language-agnostic and re-translates on display.
    private readonly (string Key, string Value)[] goals =
    {
        ("bi-chat-dots", "wizard.goal.communication"),
        ("bi-briefcase", "wizard.goal.internship"),
        ("bi-trophy", "wizard.goal.leadership"),
        ("bi-people", "wizard.goal.teamwork")
    };

    private bool saving;
    private string? savedMessage;
    private int toastSeq; // bumped each save so the toast remounts and replays its animation
    private string? avatarError;

    private bool showSuspend;
    private bool showDelete;
    private string deleteConfirmText = "";
    private string DeleteWord => L["settings.delete.word"];
    private bool DeleteConfirmed => string.Equals(deleteConfirmText.Trim(), DeleteWord, StringComparison.OrdinalIgnoreCase);

    protected override async Task OnInitializedAsync()
    {
        var state = await AuthProvider.GetAuthenticationStateAsync();
        userId = state.User.GetUserId();
        email = state.User.FindFirst(ClaimTypes.Email)?.Value ?? state.User.Identity?.Name;
        phone = state.User.FindFirst(ClaimTypes.MobilePhone)?.Value;

        user = await UserService.GetUserByIdAsync(userId);
        skills = await SkillService.GetAllSkillsAsync();
        selectedSkillIds.AddRange(await UserService.GetSelectedSkillIdsAsync(userId));

        // Hero stats — pull real data where we have it.
        var results = await AssessmentService.GetLatestResultsAsync(userId);
        badgeCount = results.Count();
        var progress = await ProgressService.GetUserProgressAsync(userId);
        // No streak schema yet — approximate with number of tracked skills so the tile isn't hollow.
        dayStreak = progress.Count();

        // Which external logins are currently linked to this user, and which are configured on the server.
        var appUser = await UserManagerSvc.FindByIdAsync(userId.ToString());
        var currentLogins = appUser is null ? new HashSet<string>() :
            (await UserManagerSvc.GetLoginsAsync(appUser)).Select(l => l.LoginProvider).ToHashSet();
        var configured = (await SignInManagerSvc.GetExternalAuthenticationSchemesAsync())
            .Select(s => s.Name).ToHashSet();

        linkedProviders = new()
        {
            new("Google",    "Google",    "bi-google",    "#fee2e2", "#dc2626", configured.Contains("Google"),    currentLogins.Contains("Google")),
            new("GitHub",    "GitHub",    "bi-github",    "#1f2937", "#f9fafb", configured.Contains("GitHub"),    currentLogins.Contains("GitHub")),
            new("Facebook",  "Facebook",  "bi-facebook",  "#dbeafe", "#1d4ed8", configured.Contains("Facebook"),  currentLogins.Contains("Facebook")),
            new("Microsoft", "Microsoft", "bi-microsoft", "#e0f2fe", "#0369a1", configured.Contains("Microsoft"), currentLogins.Contains("Microsoft")),
        };

        langCode = L.Code;
        if (user is not null && string.IsNullOrEmpty(user.PreferredLanguage))
            user.PreferredLanguage = langCode;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        // On a fresh browser (empty localStorage) seed the theme from the value
        // saved to the user's account. Won't override a choice made on this device.
        if (firstRender && user is not null)
        {
            await JS.InvokeVoidAsync("ssTheme.syncFromServer",
                user.Theme.ToString().ToLower(), user.ReduceMotion);
        }
    }

    private void ToggleSkill(int id)
    {
        if (!selectedSkillIds.Remove(id)) selectedSkillIds.Add(id);
    }

    private async Task SetLanguage(string code)
    {
        langCode = code;
        if (user is not null) user.PreferredLanguage = code;
        L.SetLanguage(LocalizationService.Parse(code));
        await JS.InvokeVoidAsync("ssLang.set", code);
    }

    private async Task SetTheme(ThemePreference th)
    {
        if (user is null) return;
        user.Theme = th;
        await JS.InvokeVoidAsync("ssTheme.set", th.ToString().ToLower(), user.ReduceMotion);
    }

    private async Task OnReduceMotionChanged(ChangeEventArgs e)
    {
        if (user is null) return;
        user.ReduceMotion = e.Value is bool b && b;
        await JS.InvokeVoidAsync("ssTheme.set", user.Theme.ToString().ToLower(), user.ReduceMotion);
    }

    private async Task SaveAsync()
    {
        if (user is null) return;
        saving = true;
        savedMessage = null;
        try
        {
            await UserService.UpdateSettingsAsync(userId, user);
            await UserService.AddSkillSelectionsAsync(userId, selectedSkillIds);
            savedMessage = L["settings.saved"];
            toastSeq++; // bump so the toast remounts and replays its animation
        }
        finally
        {
            saving = false;
        }
    }

    private void CancelDelete()
    {
        showDelete = false;
        deleteConfirmText = "";
    }

    private async Task OnAvatarSelected(InputFileChangeEventArgs e)
    {
        avatarError = null;
        var file = e.File;
        if (file is null || user is null) return;
        if (file.Size > MaxAvatarBytes) { avatarError = L["profile.avatar.tooLarge"]; return; }
        if (!file.ContentType.StartsWith("image/")) { avatarError = L["profile.avatar.notImage"]; return; }

        try
        {
            var ext = Path.GetExtension(file.Name);
            if (string.IsNullOrWhiteSpace(ext)) ext = ".png";
            var fileName = $"user{userId}_{Guid.NewGuid():N}{ext}";
            var dir = Path.Combine(Env.WebRootPath, "uploads", "avatars");
            Directory.CreateDirectory(dir);
            await using (var fs = new FileStream(Path.Combine(dir, fileName), FileMode.Create))
            {
                await file.OpenReadStream(MaxAvatarBytes).CopyToAsync(fs);
            }
            user.AvatarUrl = $"/uploads/avatars/{fileName}";
            await UserService.SetAvatarAsync(userId, user.AvatarUrl);
        }
        catch (Exception ex)
        {
            avatarError = L["profile.avatar.uploadFailed"] + " " + ex.Message;
        }
    }
}
