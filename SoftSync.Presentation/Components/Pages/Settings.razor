@page "/settings"
@rendermode InteractiveServer
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@inherits LocalizedComponentBase
@using SoftSync.BLL.Interfaces
@using SoftSync.Common
@using SoftSync.Common.Dtos
@using SoftSync.Common.Enums
@using SoftSync.DAL.Entities
@using Microsoft.AspNetCore.Identity
@using System.Security.Claims
@inject IUserService UserService
@inject ISkillService SkillService
@inject IAssessmentService AssessmentService
@inject IProgressService ProgressService
@inject UserManager<ApplicationUser> UserManagerSvc
@inject SignInManager<ApplicationUser> SignInManagerSvc
@inject NavigationManager Nav
@inject AuthenticationStateProvider AuthProvider
@inject IWebHostEnvironment Env
@inject IJSRuntime JS

<div class="ss-settings-shell tw:mx-auto">
    @if (user is null)
    {
        <div class="tw:text-center tw:py-12"><div class="spinner-border text-primary" role="status"></div></div>
    }
    else
    {
        <div class="ss-settings-grid">
            <!-- Sidebar -->
            <aside class="ss-side">
                <div class="ss-side-card">
                    <div class="ss-side-eyebrow"><i class="bi bi-gear-fill tw:me-1"></i> @L["settings.eyebrow"]</div>
                    <h2 class="ss-side-title">
                        @L["settings.tab.account"]
                        <i class="bi bi-stars ss-side-star"></i>
                    </h2>
                    <p class="ss-side-sub">@L["settings.side.sub"]</p>

                    <nav class="ss-settings-nav">
                        <button class="@(tab == Tab.Account ? "active" : "")" @onclick="() => tab = Tab.Account">
                            <i class="bi bi-person-circle"></i>
                            <span>@L["settings.tab.account"]</span>
                            <i class="bi bi-chevron-right ss-nav-caret"></i>
                        </button>
                        <button class="@(tab == Tab.Learning ? "active" : "")" @onclick="() => tab = Tab.Learning">
                            <i class="bi bi-mortarboard"></i>
                            <span>@L["settings.tab.learning"]</span>
                        </button>
                        <button class="@(tab == Tab.Notifications ? "active" : "")" @onclick="() => tab = Tab.Notifications">
                            <i class="bi bi-bell"></i>
                            <span>@L["settings.tab.notifications"]</span>
                        </button>
                        <button class="@(tab == Tab.Appearance ? "active" : "")" @onclick="() => tab = Tab.Appearance">
                            <i class="bi bi-palette"></i>
                            <span>@L["settings.tab.appearance"]</span>
                        </button>
                        <button class="@(tab == Tab.Privacy ? "active" : "")" @onclick="() => tab = Tab.Privacy">
                            <i class="bi bi-shield-check"></i>
                            <span>@L["settings.tab.privacy"]</span>
                        </button>
                        <button class="@(tab == Tab.Danger ? "active" : "")" @onclick="() => tab = Tab.Danger">
                            <i class="bi bi-credit-card"></i>
                            <span>@L["settings.tab.billing"]</span>
                        </button>
                    </nav>
                </div>

                <!-- Go Premium promo -->
                <div class="ss-premium">
                    <div class="ss-premium-crown">@Crown("ss-crown-corner")</div>
                    <h5 class="ss-premium-title">@L["settings.premium.title"]</h5>
                    <p class="ss-premium-sub">@L["settings.premium.sub"]</p>
                    <button class="ss-btn-primary tw:w-full tw:py-2" type="button">
                        @Crown("tw:me-1") @L["settings.premium.cta"]
                    </button>
                </div>
            </aside>

            <!-- Main column -->
            <div class="ss-main">

                <!-- Hero banner: shows on every tab like the mockup -->
                <div class="ss-hero">
                    <div class="ss-hero-inner">
                        <div class="ss-hero-avatar">
                            @if (!string.IsNullOrEmpty(user.AvatarUrl))
                            {
                                <img src="@user.AvatarUrl" alt="avatar" class="ss-avatar-img" />
                            }
                            else
                            {
                                <img src="@Mascot.ImageFor(user.Gender)" alt="mascot"
                                     class="ss-avatar-img"
                                     onerror="this.style.display='none';this.parentElement.querySelector('.ss-hero-fallback').style.display='flex'" />
                                <span class="ss-hero-fallback">@Mascot.Emoji</span>
                            }
                            <label class="ss-avatar-edit" title="@L["profile.avatar.change"]">
                                <i class="bi bi-camera-fill"></i>
                                <InputFile OnChange="OnAvatarSelected" accept="image/*" class="tw:hidden" />
                            </label>
                        </div>

                        <div class="ss-hero-id">
                            <div class="ss-hero-name-row">
                                <h3 class="ss-hero-name">@user.PublicName</h3>
                                <span class="ss-level-badge">@L["nav.level"] @user.Level</span>
                            </div>
                            <p class="ss-hero-quote">"@L["settings.hero.quote"]"</p>
                        </div>

                        <div class="ss-hero-stats">
                            <div class="ss-stat">
                                <div class="ss-stat-icon ss-stat-icon--xp"><i class="bi bi-gem"></i></div>
                                <div class="ss-stat-num">@user.ExperiencePoints</div>
                                <div class="ss-stat-label">@L["settings.hero.xp"]</div>
                            </div>
                            <div class="ss-stat">
                                <div class="ss-stat-icon ss-stat-icon--streak"><i class="bi bi-fire"></i></div>
                                <div class="ss-stat-num">@dayStreak</div>
                                <div class="ss-stat-label">@L["settings.hero.streak"]</div>
                            </div>
                            <div class="ss-stat">
                                <div class="ss-stat-icon ss-stat-icon--badge"><i class="bi bi-award-fill"></i></div>
                                <div class="ss-stat-num">@badgeCount</div>
                                <div class="ss-stat-label">@L["settings.hero.badges"]</div>
                            </div>
                        </div>
                    </div>
                    @if (!string.IsNullOrEmpty(avatarError))
                    {
                        <div class="text-danger tw:text-sm tw:px-6 tw:pb-3">@avatarError</div>
                    }
                </div>

                <!-- Panels -->
                @switch (tab)
                {
                    case Tab.Account:
                        <div class="ss-card ss-card--flat tw:p-6">
                            <div class="tw:flex tw:items-center tw:justify-between tw:mb-5 tw:flex-wrap tw:gap-3">
                                <h4 class="ss-panel-title">@L["settings.profile.info"]</h4>
                                <a class="ss-ghost-btn" href="Account/ChangePassword">
                                    <i class="bi bi-lock"></i> @L["settings.password.title"]
                                </a>
                            </div>

                            <div class="tw:grid tw:grid-cols-1 tw:sm:grid-cols-2 tw:gap-4">
                                <div class="ss-field">
                                    <i class="bi bi-person ss-field-icon"></i>
                                    <div class="ss-field-body">
                                        <label for="fullName" class="ss-field-label">@L["profile.fullName"]</label>
                                        <input id="fullName" class="ss-field-input" @bind="user.FullName" />
                                    </div>
                                </div>
                                <div class="ss-field">
                                    <i class="bi bi-pencil ss-field-icon"></i>
                                    <div class="ss-field-body">
                                        <label for="displayName" class="ss-field-label">@L["settings.displayName"]</label>
                                        <input id="displayName" class="ss-field-input" @bind="user.DisplayName" placeholder="@user.FullName" />
                                    </div>
                                </div>
                                <div class="ss-field">
                                    <i class="bi bi-envelope ss-field-icon"></i>
                                    <div class="ss-field-body">
                                        <label for="email" class="ss-field-label">@L["auth.email"]</label>
                                        <input id="email" class="ss-field-input" value="@email" disabled />
                                    </div>
                                </div>
                                <div class="ss-field">
                                    <i class="bi bi-telephone ss-field-icon"></i>
                                    <div class="ss-field-body">
                                        <label for="phone" class="ss-field-label">@L["auth.phone"]</label>
                                        <input id="phone" class="ss-field-input" value="@phone" disabled placeholder="—" />
                                    </div>
                                </div>
                            </div>

                            <h5 class="ss-section-heading tw:mt-6 tw:mb-3">@L["settings.linkedAccounts"]</h5>
                            <div class="ss-linked-grid">
                                @foreach (var p in linkedProviders)
                                {
                                    <div class="ss-linked">
                                        <div class="ss-linked-icon" style="background:@p.Bg;color:@p.Fg"><i class="bi @p.Icon"></i></div>
                                        <div class="ss-linked-body">
                                            <div class="ss-linked-name">@p.Name</div>
                                            <div class="ss-linked-state @(p.Connected ? "connected" : "")">
                                                @(p.Connected ? L["settings.linked.connected"] : L["settings.linked.notConnected"])
                                            </div>
                                        </div>
                                        @if (p.Connected)
                                        {
                                            <span class="ss-linked-check" title="@L["settings.linked.connected"]"><i class="bi bi-check-circle-fill"></i></span>
                                        }
                                        else if (p.Available)
                                        {
                                            <form action="Account/PerformExternalLogin" method="post" class="tw:m-0">
                                                <AntiforgeryToken />
                                                <input type="hidden" name="ReturnUrl" value="/settings" />
                                                <button type="submit" name="provider" value="@p.Scheme" class="ss-linked-btn">
                                                    @L["settings.linked.connect"]
                                                </button>
                                            </form>
                                        }
                                        else
                                        {
                                            <button class="ss-linked-btn" type="button" disabled title="@L["auth.googleNotConfigured"]">
                                                @L["settings.linked.connect"]
                                            </button>
                                        }
                                    </div>
                                }
                            </div>

                            <div class="tw:flex tw:items-center tw:justify-between tw:mt-6 tw:flex-wrap tw:gap-3">
                                <div class="text-muted tw:text-sm tw:flex tw:items-center tw:gap-2">
                                    <i class="bi bi-shield-lock"></i> @L["settings.secureNote"]
                                </div>
                                <button class="ss-btn-primary tw:px-6 tw:py-2" @onclick="SaveAsync" disabled="@saving">
                                    <i class="bi bi-stars tw:me-1"></i> @L["settings.save"]
                                </button>
                            </div>
                        </div>
                        break;

                    case Tab.Learning:
                        <div class="ss-card ss-card--flat tw:p-6">
                            <h4 class="ss-panel-title tw:mb-1">@L["settings.tab.learning"]</h4>
                            <p class="text-muted tw:text-sm tw:mb-4">@L["settings.learning.hint"]</p>

                            <label class="form-label tw:font-medium">@L["profile.goal"]</label>
                            <div class="tw:flex tw:flex-wrap tw:gap-2 tw:mb-4">
                                @foreach (var g in goals)
                                {
                                    <button type="button" class="ss-seg-1 @(user.Goal == g.Value ? "active" : "")" @onclick="() => user.Goal = g.Value">
                                        <i class="bi @g.Key tw:me-1"></i> @L[g.Value]
                                    </button>
                                }
                            </div>

                            <label class="form-label tw:font-medium">@L["settings.prioritySkills"]</label>
                            <div class="tw:flex tw:flex-wrap tw:gap-2 tw:mb-4">
                                @if (skills is not null)
                                {
                                    @foreach (var s in skills)
                                    {
                                        <button class="ss-seg-1 @(selectedSkillIds.Contains(s.Id) ? "active" : "")"
                                                @onclick="() => ToggleSkill(s.Id)" type="button">
                                            <i class="bi @s.IconName tw:me-1"></i> @s.Name
                                        </button>
                                    }
                                }
                            </div>

                            <label class="form-label tw:font-medium">@L["settings.currentLevel"]</label>
                            <div class="ss-seg tw:mb-4">
                                @foreach (var lvl in new[] { LearningLevel.Beginner, LearningLevel.Intermediate, LearningLevel.Advanced })
                                {
                                    <button type="button" class="@(user.CurrentLevel == lvl ? "active" : "")" @onclick="() => user.CurrentLevel = lvl">
                                        @L[$"settings.level.{lvl.ToString().ToLower()}"]
                                    </button>
                                }
                            </div>

                            <div class="tw:grid tw:grid-cols-1 tw:sm:grid-cols-2 tw:gap-4 tw:mb-4">
                                <div>
                                    <label class="form-label tw:font-medium">@L["settings.dailyMinutes"]</label>
                                    <select class="form-control" @bind="user.DailyStudyMinutes">
                                        <option value="0">—</option>
                                        <option value="15">15 @L["settings.minutes"]</option>
                                        <option value="30">30 @L["settings.minutes"]</option>
                                        <option value="45">45 @L["settings.minutes"]</option>
                                        <option value="60">60 @L["settings.minutes"]</option>
                                        <option value="90">90 @L["settings.minutes"]</option>
                                    </select>
                                </div>
                                <div>
                                    <label class="form-label tw:font-medium">@L["settings.daysPerWeek"]</label>
                                    <select class="form-control" @bind="user.StudyDaysPerWeek">
                                        @for (var d = 0; d <= 7; d++)
                                        {
                                            <option value="@d">@(d == 0 ? "—" : d.ToString())</option>
                                        }
                                    </select>
                                </div>
                            </div>

                            <label class="form-label tw:font-medium">@L["settings.preferredTime"]</label>
                            <div class="ss-seg tw:mb-4">
                                @foreach (var t in new[] { StudyTime.Morning, StudyTime.Afternoon, StudyTime.Evening, StudyTime.Night })
                                {
                                    <button type="button" class="@(user.PreferredStudyTime == t ? "active" : "")" @onclick="() => user.PreferredStudyTime = t">
                                        @L[$"settings.time.{t.ToString().ToLower()}"]
                                    </button>
                                }
                            </div>

                            <button class="ss-btn-primary tw:mt-2 tw:px-6 tw:py-2" @onclick="SaveAsync" disabled="@saving">
                                <i class="bi bi-stars tw:me-1"></i> @L["settings.save"]
                            </button>
                        </div>
                        break;

                    case Tab.Notifications:
                        <div class="ss-card ss-card--flat tw:p-6">
                            <h4 class="ss-panel-title tw:mb-1">@L["settings.tab.notifications"]</h4>
                            <p class="text-muted tw:text-sm tw:mb-4">@L["settings.notifications.hint"]</p>
                            <div class="ss-notif-row">
                                <div>
                                    <div class="tw:font-semibold">@L["settings.notif.study"]</div>
                                    <div class="text-muted tw:text-sm">@L["settings.notif.study.hint"]</div>
                                </div>
                                <div class="form-check form-switch tw:m-0">
                                    <input class="form-check-input" type="checkbox" @bind="notifStudy" />
                                </div>
                            </div>
                            <div class="ss-notif-row">
                                <div>
                                    <div class="tw:font-semibold">@L["settings.notif.progress"]</div>
                                    <div class="text-muted tw:text-sm">@L["settings.notif.progress.hint"]</div>
                                </div>
                                <div class="form-check form-switch tw:m-0">
                                    <input class="form-check-input" type="checkbox" @bind="notifProgress" />
                                </div>
                            </div>
                            <div class="ss-notif-row">
                                <div>
                                    <div class="tw:font-semibold">@L["settings.notif.community"]</div>
                                    <div class="text-muted tw:text-sm">@L["settings.notif.community.hint"]</div>
                                </div>
                                <div class="form-check form-switch tw:m-0">
                                    <input class="form-check-input" type="checkbox" @bind="notifCommunity" />
                                </div>
                            </div>
                            <p class="text-muted tw:text-xs tw:mt-3"><i class="bi bi-info-circle tw:me-1"></i>@L["settings.notif.preview"]</p>
                        </div>
                        break;

                    case Tab.Appearance:
                        <div class="ss-card ss-card--flat tw:p-6">
                            <h4 class="ss-panel-title tw:mb-4">@L["settings.tab.appearance"]</h4>

                            <label class="form-label tw:font-medium">@L["settings.language"]</label>
                            <div class="ss-seg tw:mb-4">
                                <button type="button" class="@(langCode == "vi" ? "active" : "")" @onclick='() => SetLanguage("vi")'>Tiếng Việt</button>
                                <button type="button" class="@(langCode == "en" ? "active" : "")" @onclick='() => SetLanguage("en")'>English</button>
                            </div>

                            <label class="form-label tw:font-medium">@L["settings.theme"]</label>
                            <div class="ss-seg tw:mb-4">
                                @foreach (var th in new[] { ThemePreference.Light, ThemePreference.Dark, ThemePreference.System })
                                {
                                    <button type="button" class="@(user.Theme == th ? "active" : "")" @onclick="() => SetTheme(th)">
                                        @L[$"settings.theme.{th.ToString().ToLower()}"]
                                    </button>
                                }
                            </div>

                            <div class="form-check form-switch tw:mb-2">
                                <input class="form-check-input" type="checkbox" id="reduceMotion" checked="@user.ReduceMotion"
                                       @onchange="OnReduceMotionChanged" />
                                <label class="form-check-label tw:font-medium" for="reduceMotion">@L["settings.reduceMotion"]</label>
                            </div>
                            <p class="text-muted tw:text-sm tw:mb-4">@L["settings.reduceMotion.hint"]</p>

                            <button class="ss-btn-primary tw:px-6 tw:py-2" @onclick="SaveAsync" disabled="@saving">
                                <i class="bi bi-stars tw:me-1"></i> @L["settings.save"]
                            </button>
                        </div>
                        break;

                    case Tab.Privacy:
                        <div class="ss-card ss-card--flat tw:p-6">
                            <h4 class="ss-panel-title tw:mb-1">@L["settings.tab.privacy"]</h4>
                            <p class="text-muted tw:text-sm tw:mb-4">@L["settings.privacy.hint"]</p>
                            <div class="ss-notif-row">
                                <div>
                                    <div class="tw:font-semibold">@L["settings.privacy.profile"]</div>
                                    <div class="text-muted tw:text-sm">@L["settings.privacy.profile.hint"]</div>
                                </div>
                                <div class="form-check form-switch tw:m-0">
                                    <input class="form-check-input" type="checkbox" @bind="publicProfile" />
                                </div>
                            </div>
                            <div class="ss-notif-row">
                                <div>
                                    <div class="tw:font-semibold">@L["settings.privacy.leaderboard"]</div>
                                    <div class="text-muted tw:text-sm">@L["settings.privacy.leaderboard.hint"]</div>
                                </div>
                                <div class="form-check form-switch tw:m-0">
                                    <input class="form-check-input" type="checkbox" @bind="showOnLeaderboard" />
                                </div>
                            </div>
                            <p class="text-muted tw:text-xs tw:mt-3"><i class="bi bi-info-circle tw:me-1"></i>@L["settings.notif.preview"]</p>
                        </div>
                        break;

                    case Tab.Danger:
                        <div class="ss-card ss-card--flat tw:p-6 tw:mb-4">
                            <h4 class="ss-panel-title tw:mb-1">@L["settings.tab.billing"]</h4>
                            <p class="text-muted tw:text-sm tw:mb-4">@L["settings.billing.hint"]</p>

                            <div class="ss-billing-plan">
                                <div>
                                    <div class="tw:font-semibold">@L["settings.billing.currentPlan"]</div>
                                    <div class="text-muted tw:text-sm">@L["settings.billing.freePlan"]</div>
                                </div>
                                <button class="ss-btn-primary tw:px-4 tw:py-2" type="button">
                                    @Crown("tw:me-1") @L["settings.premium.cta"]
                                </button>
                            </div>
                        </div>

                        <div class="ss-card ss-card--flat tw:p-6 tw:mb-4">
                            <h5 class="tw:font-bold tw:mb-3">@L["settings.session"]</h5>
                            <form id="ss-settings-logout" action="Account/Logout" method="post" class="tw:m-0">
                                <AntiforgeryToken />
                                <input type="hidden" name="ReturnUrl" value="" />
                                <button type="submit" class="btn btn-light tw:py-2 tw:px-4">
                                    <i class="bi bi-box-arrow-right tw:me-1"></i> @L["nav.logout"]
                                </button>
                            </form>
                        </div>

                        <div class="ss-card ss-card--flat ss-danger-zone tw:p-6">
                            <h5 class="tw:font-bold tw:mb-1 text-danger">@L["settings.danger"]</h5>
                            <p class="text-muted tw:text-sm tw:mb-4">@L["settings.danger.hint"]</p>

                            <div class="tw:flex tw:items-center tw:justify-between tw:gap-3 tw:mb-3 tw:flex-wrap">
                                <div>
                                    <div class="tw:font-semibold">@L["settings.suspend.title"]</div>
                                    <div class="text-muted tw:text-sm">@L["settings.suspend.hint"]</div>
                                </div>
                                <button class="btn btn-outline-warning tw:py-2 tw:px-4" @onclick="() => showSuspend = true">
                                    @L["settings.suspend.button"]
                                </button>
                            </div>
                            <hr />
                            <div class="tw:flex tw:items-center tw:justify-between tw:gap-3 tw:flex-wrap">
                                <div>
                                    <div class="tw:font-semibold text-danger">@L["settings.delete.title"]</div>
                                    <div class="text-muted tw:text-sm">@L["settings.delete.hint"]</div>
                                </div>
                                <button class="btn btn-danger tw:py-2 tw:px-4" @onclick="() => showDelete = true">
                                    @L["settings.delete.button"]
                                </button>
                            </div>
                        </div>
                        break;
                }
            </div>
        </div>
    }
</div>

@* Floating glass toast — replays its show→hold→fade animation each time
   toastSeq changes (i.e. each save). Ends invisible with pointer-events:none. *@
@if (!string.IsNullOrEmpty(savedMessage))
{
    <div class="ss-toast" @key="toastSeq" role="status" aria-live="polite">
        <i class="bi bi-check-circle-fill"></i>
        <span>@savedMessage</span>
    </div>
}

<!-- Suspend confirm -->
@if (showSuspend)
{
    <div class="ss-modal-backdrop" @onclick="() => showSuspend = false">
        <div class="ss-modal" @onclick:stopPropagation="true">
            <h4 class="tw:font-bold tw:mb-2">@L["settings.suspend.title"]</h4>
            <p class="text-muted tw:mb-4">@L["settings.suspend.confirm"]</p>
            <form id="ss-suspend-form" action="Account/Suspend" method="post" class="tw:m-0">
                <AntiforgeryToken />
                <div class="tw:flex tw:gap-3">
                    <button type="button" class="btn btn-light tw:flex-1 tw:py-2" @onclick="() => showSuspend = false">@L["logout.confirm.cancel"]</button>
                    <button type="submit" class="btn btn-warning tw:flex-1 tw:py-2">@L["settings.suspend.button"]</button>
                </div>
            </form>
        </div>
    </div>
}

<!-- Delete confirm (typed) -->
@if (showDelete)
{
    <div class="ss-modal-backdrop" @onclick="CancelDelete">
        <div class="ss-modal" @onclick:stopPropagation="true">
            <h4 class="tw:font-bold tw:mb-2 text-danger">@L["settings.delete.title"]</h4>
            <p class="text-muted tw:mb-3">@L["settings.delete.confirm"]</p>
            <p class="tw:text-sm tw:mb-2">@L["settings.delete.typePrompt"] <strong>@DeleteWord</strong></p>
            <input class="form-control tw:mb-4" @bind="deleteConfirmText" @bind:event="oninput" placeholder="@DeleteWord" />
            <form id="ss-delete-form" action="Account/DeleteAccount" method="post" class="tw:m-0">
                <AntiforgeryToken />
                <div class="tw:flex tw:gap-3">
                    <button type="button" class="btn btn-light tw:flex-1 tw:py-2" @onclick="CancelDelete">@L["logout.confirm.cancel"]</button>
                    <button type="submit" class="btn btn-danger tw:flex-1 tw:py-2" disabled="@(!DeleteConfirmed)">@L["settings.delete.button"]</button>
                </div>
            </form>
        </div>
    </div>
}

@code {
    // Bootstrap Icons has no "crown" glyph, so render a gold crown as inline SVG.
    private static Microsoft.AspNetCore.Components.MarkupString Crown(string cssClass = "") =>
        new($"<svg class=\"ss-crown {cssClass}\" viewBox=\"0 0 576 512\" width=\"1em\" height=\"1em\" aria-hidden=\"true\" focusable=\"false\">" +
