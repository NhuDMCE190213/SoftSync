@page "/assessment-result/{UserId:int}"
@using SoftSync.BLL.Interfaces
@using SoftSync.Common.Dtos
@inject IAssessmentService AssessmentService
@inject NavigationManager Nav

<div class="max-800 mx-auto">
    <StepIndicator CurrentStep="4" />

    <div class="text-center mb-5">
        <h2 class="fw-bold">Your <span class="ss-gradient-text">Soft Skills Profile</span></h2>
        <p class="text-muted">Based on your assessment, here is where you stand.</p>
    </div>

    @if (results == null)
    {
        <div class="text-center py-5">Loading results...</div>
    }
    else
    {
        <div class="row g-4 mb-5">
            @foreach (var res in results)
            {
                <div class="col-md-6">
                    <div class="ss-card p-4">
                        <div class="d-flex justify-content-between mb-2">
                            <h5 class="fw-bold mb-0">@res.SkillName</h5>
                            <span class="badge @GetLevelBadgeClass(res.Level)">@res.Level</span>
                        </div>
                        <div class="progress mb-3" style="height: 12px; border-radius: 6px;">
                            <div class="progress-bar" style="width: @(res.Score)%; background: var(--gradient);"></div>
                        </div>
                        <p class="small text-muted mb-0">
                            @(res.Score > 70 ? "Excellent work! Keep honing this skill." : "Focusing on this area will significantly help your career.")
                        </p>
                    </div>
                </div>
            }
        </div>

        <div class="ss-card p-5 text-center mb-5" style="background: var(--gradient-soft);">
            <h4 class="fw-bold mb-3">AI Recommendation</h4>
            <p class="fs-5 mb-4">
                "You show a great foundation in <strong>Communication</strong>, but your roadmap suggests prioritizing 
                <strong>Teamwork</strong> scenarios to balance your skill set."
            </p>
            <button class="ss-btn-primary px-5 py-3 fs-5" @onclick="GoToRoadmap">
                View My Roadmap <i class="bi bi-calendar-check ms-2"></i>
            </button>
        </div>
    }
</div>

@code {
    [Parameter] public int UserId { get; set; }
    private IEnumerable<AssessmentResultDto>? results;

    protected override async Task OnInitializedAsync()
    {
        results = await AssessmentService.GetLatestResultsAsync(UserId);
    }

    private string GetLevelBadgeClass(SoftSync.Common.Enums.AssessmentLevel level) => level switch
    {
        SoftSync.Common.Enums.AssessmentLevel.Good => "bg-success",
        SoftSync.Common.Enums.AssessmentLevel.Average => "bg-warning",
        _ => "bg-danger"
    };

    private void GoToRoadmap() => Nav.NavigateTo($"/roadmap/{UserId}");
}

<style>
    .max-800 { max-width: 800px; }
</style>
