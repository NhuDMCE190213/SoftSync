@page "/community"
@using SoftSync.BLL.Interfaces
@using SoftSync.Common.Dtos
@inject IMentorService MentorService
@inject NavigationManager Nav
@inject IMentorService MentorService

@attribute [Authorize]

<div class="max-800 mx-auto">
    <div class="mb-5">
        <h2 class="fw-bold mb-1"><span class="ss-gradient-text">Mentor</span> Hỗ trợ</h2>
        <p class="text-muted">Kết nối với các chuyên gia để thúc đẩy sự phát triển của bạn.</p>
    </div>

    <div class="row g-4">
        @if (mentors == null)
        {
            <div class="col-12 text-center">Đang tải các chuyên gia...</div>
        }
        else
        {
            @foreach (var mentor in mentors)
            {
                <div class="col-md-6">
                    <div class="ss-card p-4 h-100">
                        <div class="d-flex align-items-center gap-3 mb-3">
                            <img src="@mentor.AvatarUrl" class="rounded-circle" style="width: 64px; height: 64px; object-fit: cover;" />
                            <div>
                                <h5 class="fw-bold mb-0">@mentor.Name</h5>
                                <span class="small text-primary">@mentor.Expertise</span>
                            </div>
                        </div>
                        <p class="text-muted small mb-4">@mentor.ShortBio</p>
                        <button class="btn btn-outline-primary w-100 py-2 rounded-pill" @onclick='() => Nav.NavigateTo($"/community/chat/{mentor.Id}")'>
                            Kết nối
                        </button>
                    </div>
                </div>
            }
        }
    </div>
</div>

@code {
    private IEnumerable<MentorDto>? mentors;
    private string? notification;

    protected override async Task OnInitializedAsync()
    {
        mentors = await MentorService.GetAllAsync();
    }
}

<style>
    .max-800 { max-width: 800px; }
</style>
