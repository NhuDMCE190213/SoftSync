@page "/assessment/{UserId:int}"
@using SoftSync.BLL.Interfaces
@using SoftSync.BLL.Services
@using SoftSync.Common.Dtos.EntryTest
@inject IEntryTestService EntryTestService
@inject IRoadmapService RoadmapService
@inject NavigationManager Nav
@attribute [Authorize]

<div class="max-800 mx-auto">
    <StepIndicator CurrentStep="3" />

    @if (questions == null)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status"></div>
            <p class="mt-3">Đang chuẩn bị bài đánh giá AI của bạn...</p>
        </div>
    }
    else if (currentQuestionIndex < questions.Count)
    {
        var q = questions[currentQuestionIndex];
        <div class="ss-card p-5">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <span class="badge bg-primary px-3 py-2">Câu hỏi @(currentQuestionIndex + 1) trong @questions.Count</span>
                <span class="text-muted small">Kỹ năng: @GetSkillName(q.SkillId)</span>
            </div>
            
            <h3 class="fw-bold mb-4">@q.QuestionText</h3>
            
            <div class="d-grid gap-3">
                @foreach (var opt in q.Options)
                {
                    <button class="btn btn-outline-primary text-start p-4 fs-5 @(selectedOptionId == opt.Id ? "active" : "")"
                            @onclick="() => SelectOption(opt.Id)">
                        @opt.OptionText
                    </button>
                }
            </div>

            <div class="mt-5 d-flex justify-content-end">
                <button class="ss-btn-primary px-5" @onclick="NextQuestion" disabled="@(selectedOptionId == 0)">
                    @(currentQuestionIndex == questions.Count - 1 ? "Hoàn thành" : "Câu hỏi tiếp theo")
                </button>
            </div>
        </div>
    }
    else
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status"></div>
            <p class="mt-3">Đang phân tích kỹ năng mềm của bạn với AI...</p>
        </div>
    }
</div>

@code {
    [Parameter] public int UserId { get; set; }
    private List<EntryTestQuestionDto>? questions;
    private int currentQuestionIndex = 0;
    private int selectedOptionId = 0;
    private List<EntryTestAnswerDto> answers = new();
    [SupplyParameterFromQuery(Name = "skillIds")]
    public string? SkillIdsQuery { get; set; }

    protected override async Task OnInitializedAsync()
    {
        var filterIds = string.IsNullOrEmpty(SkillIdsQuery)
            ? null
            : SkillIdsQuery.Split(',').Select(int.Parse).ToList();
        questions = await EntryTestService.GetQuestionsAsync(UserId, filterIds);
    }

    private void SelectOption(int id) => selectedOptionId = id;

    private async Task NextQuestion()
    {
        answers.Add(new EntryTestAnswerDto { QuestionId = questions![currentQuestionIndex].Id, OptionId = selectedOptionId });

        if (currentQuestionIndex < questions.Count - 1)
        {
            currentQuestionIndex++;
            selectedOptionId = 0;
        }
        else
        {
            currentQuestionIndex++;
            await EntryTestService.SubmitAsync(UserId, answers);
            await RoadmapService.GenerateRoadmapAsync(UserId);
            Nav.NavigateTo($"/assessment-result/{UserId}");
        }
    }

    private string GetSkillName(int skillId) => skillId switch
    {
        1 => "Quản lý thời gian",
        2 => "Giao tiếp",
        3 => "Tư duy phản biện",
        _ => ""
    };
}

<style>
    .max-800 { max-width: 800px; }
    .btn-outline-primary {
        border: 2px solid #e2e8f0;
        color: var(--text);
        border-radius: 1rem;
    }
    .btn-outline-primary:hover {
        background: #f8fafc;
        border-color: var(--primary);
        color: var(--primary);
    }
    .btn-outline-primary.active {
        background: var(--gradient-soft);
        border-color: var(--primary);
        color: var(--primary);
    }
</style>
