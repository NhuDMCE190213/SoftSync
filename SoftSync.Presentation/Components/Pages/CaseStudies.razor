@page "/case-studies"
@using SoftSync.BLL.Interfaces
@using SoftSync.Common.Dtos
@inject ICaseStudyService CaseStudyService

@attribute [Authorize]

<div class="max-800 mx-auto">
    <div class="mb-5">
        <h2 class="fw-bold mb-1">Interactive <span class="ss-gradient-text">Case Studies</span></h2>
        <p class="text-muted">Apply your knowledge to real-world scenarios.</p>
    </div>

    @if (caseStudy == null)
    {
        <div class="text-center py-5">Loading case studies...</div>
    }
    else
    {
        <div class="ss-card mb-5 overflow-hidden">
            <div class="bg-primary text-white p-3 px-4 fw-bold">CASE STUDY: @caseStudy.Title</div>
            <div class="p-5">
                <p class="fs-5 mb-5 lh-lg">@caseStudy.Scenario</p>

                <h6 class="fw-bold text-uppercase small text-muted mb-3">How would you respond?</h6>
                <div class="d-grid gap-3">
                    @foreach (var opt in caseStudy.Options)
                    {
                        <button class="btn btn-outline-primary text-start p-3 fs-5" 
                                @onclick="() => SelectOption(opt)"
                                disabled="@(feedback != null)">
                            @opt.OptionText
                        </button>
                    }
                </div>

                @if (feedback != null)
                {
                    <div class="mt-5 p-4 rounded-3 @(isCorrect ? "bg-success-subtle border-success" : "bg-warning-subtle border-warning") border">
                        <div class="d-flex gap-3">
                            <i class="bi @(isCorrect ? "bi-check-circle-fill text-success" : "bi-exclamation-triangle-fill text-warning") fs-4"></i>
                            <div>
                                <h5 class="fw-bold @(isCorrect ? "text-success" : "text-warning")">@(isCorrect ? "Great Choice!" : "Room for Improvement")</h5>
                                <p class="mb-0 text-dark">@feedback</p>
                            </div>
                        </div>
                    </div>
                    <div class="mt-4 text-center">
                        <button class="btn btn-primary px-4 py-2" @onclick="LoadNext">Try Another Case</button>
                    </div>
                }
            </div>
        </div>
    }
</div>

@code {
    private CaseStudyDto? caseStudy;
    private string? feedback;
    private bool isCorrect;

    protected override async Task OnInitializedAsync()
    {
        await LoadNext();
    }

    private async Task LoadNext()
    {
        feedback = null;
        var list = await CaseStudyService.GetCaseStudiesBySkillAsync(1); // Communication for demo
        var random = new Random();
        var id = list.ElementAt(random.Next(list.Count())).Id;
        caseStudy = await CaseStudyService.GetCaseStudyByIdAsync(id);
    }

    private void SelectOption(CaseStudyOptionDto opt)
    {
        feedback = opt.Feedback;
        isCorrect = opt.IsRecommended;
    }
}

<style>
    .max-800 { max-width: 800px; }
    .bg-success-subtle { background: #dcfce7 !important; }
    .bg-warning-subtle { background: #fef9c3 !important; }
</style>
