@page "/profile-setup"
@using SoftSync.BLL.Interfaces
@using SoftSync.Common.Dtos
@using SoftSync.Presentation.Infrastructure
@inject IUserService UserService
@inject CurrentUserAccessor CurrentUserAccessor
@inject NavigationManager Nav

@attribute [Authorize]

<div class="max-600 mx-auto">
    <StepIndicator CurrentStep="1" />

    <div class="ss-card p-5">
        <h2 class="fw-bold mb-4">Cài đặt hồ sơ của bạn</h2>
        @if (loading)
        {
            <p class="text-muted">Đang tải...</p>
        }
        else
        {
            <div class="mb-3">
                <label class="form-label fw-medium">Họ và tên</label>
                <input type="text" class="form-control form-control-lg p-3" @bind="fullName" placeholder="e.g. John Doe" />
            </div>
            <div class="row mb-3">
                <div class="col-md-6">
                    <label class="form-label fw-medium">Tuổi</label>
                    <input type="number" class="form-control form-control-lg p-3" @bind="age" />
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-medium">Vai trò</label>
                    <select class="form-select form-select-lg p-3" @bind="role">
                        <option value="Student">Học sinh/Sinh viên</option>
                    </select>
                </div>
            </div>
            <div class="mb-4">
                <label class="form-label fw-medium">Mục tiêu học tập của bạn là gì?</label>
                <textarea class="form-control form-control-lg p-3" rows="3" @bind="goal" placeholder="e.g. Cải thiện kỹ năng giao tiếp cho phỏng vấn xin việc"></textarea>
            </div>
            <button class="ss-btn-primary w-100 py-3 fs-5" @onclick="HandleSubmit">
                Tiếp tục <i class="bi bi-arrow-right ms-2"></i>
            </button>
        }
    </div>
</div>

@code {
    private int userId;
    private bool loading = true;
    private string fullName = string.Empty;
    private int age;
    private string goal = string.Empty;
    private SoftSync.Common.Enums.UserRole role = SoftSync.Common.Enums.UserRole.Student;

    protected override async Task OnInitializedAsync()
    {
        var id = await CurrentUserAccessor.GetUserIdAsync();
        if (!id.HasValue)
        {
            Nav.NavigateTo("/login");
            return;
        }
        userId = id.Value;

        // Prefill dữ liệu đã có từ Register, tránh bắt nhập lại
        var existing = await UserService.GetUserByIdAsync(userId);
        if (existing != null)
        {
            fullName = existing.FullName;
            age = existing.Age;
            goal = existing.Goal;
        }
        loading = false;
    }

    private async Task HandleSubmit()
    {
        if (string.IsNullOrWhiteSpace(fullName)) return;

        await UserService.UpdateProfileAsync(userId, fullName, age, goal); // ✅ update user thật, không tạo mới
        Nav.NavigateTo($"/select-skills/{userId}"); // ✅ dùng đúng ID user đang đăng nhập
    }
}