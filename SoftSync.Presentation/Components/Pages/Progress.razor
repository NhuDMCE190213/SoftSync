@page "/progress"
@using SoftSync.BLL.Interfaces
@using SoftSync.BLL.Services
@using SoftSync.Common.Dtos
@using SoftSync.Common.Dtos.Roadmap
@using SoftSync.Presentation.Infrastructure
@inject NavigationManager Nav
@inject IProgressService ProgressService
@inject CurrentUserAccessor CurrentUserAccessor

@attribute [Authorize]

<div class="max-800 mx-auto">
    <div class="mb-5">
        <h2 class="fw-bold mb-1">Tiến độ <span class="ss-gradient-text">Học tập</span></h2>
        <p class="text-muted">Theo dõi sự phát triển của bạn qua các kỹ năng mềm.</p>
    </div>

    @if (progressLogs == null)
    {
        <div class="text-center py-5">Đang tải thống kê của bạn...</div>
    }
    else if (!progressLogs.Any())
    {
        <div class="ss-card p-5 text-center">
            <i class="bi bi-lightning-charge fs-1 text-muted mb-3"></i>
            <h4>Chưa có dữ liệu</h4>
            <p class="text-muted">Bắt đầu học và hoàn thành lộ trình của bạn để xem tiến độ tại đây!</p>
            <a href="/" class="btn btn-primary mt-3">Bắt đầu ngay</a>
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var p in progressLogs)
            {
                <div class="col-md-12">
                    <div class="ss-card p-4">
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <h5 class="fw-bold mb-0">@p.SkillName</h5>
                            <span class="fw-bold ss-gradient-text fs-4">@p.PercentComplete%</span>
                        </div>
                        <div class="progress" style="height: 20px; border-radius: 10px;">
                            <div class="progress-bar progress-bar-striped progress-bar-animated" 
                                 style="width: @p.PercentComplete%; background: var(--gradient);"></div>
                        </div>
                        <div class="mt-3 small text-muted">
                            Last active: @p.UpdatedAt.ToString("MMM dd, yyyy")
                        </div>
                    </div>
                </div>
            }
            <div class="text-center mt-4">
                <button class="btn btn-outline-primary" @onclick='() => Nav.NavigateTo("/roadmap")'>Quay lại lộ trình</button>
            </div>
        </div>
    }
</div>

@code {
    private int? userId;
    private RoadmapDto? roadmap;
    private IEnumerable<ProgressDto>? progressLogs;

    protected override async Task OnInitializedAsync()
    {
        userId = await CurrentUserAccessor.GetUserIdAsync();
        if (userId.HasValue)
        {
            progressLogs = await ProgressService.GetUserProgressAsync(userId.Value);
        }
    }
}

<style>
    .max-800 { max-width: 800px; }
</style>
