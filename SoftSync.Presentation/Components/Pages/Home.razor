@page "/"
@inject NavigationManager Nav

@attribute [Authorize]

<div class="hero-section py-5">
    <div class="row align-items-center g-5">
        <div class="col-lg-6">
            <div class="d-flex align-items-center gap-3 mb-4">
                <div class="logo-container overflow-hidden">
                    <img src="images/logo.png" alt="SoftSync Logo" class="w-100 h-100 object-fit-cover" />
                </div>
                <div>
                    <h1 class="display-3 fw-bold mb-0 ss-gradient-text">SoftSync</h1>
                    <p class="text-muted fw-medium mb-0">AI-powered soft skills learning app</p>
                </div>
            </div>
            
            <h2 class="display-5 fw-bold mb-4">Master your future with <span class="text-primary">Intelligence</span>.</h2>
            <p class="lead text-muted mb-5">
                SoftSync is an AI-powered platform that helps you assess your soft skills, 
                practice through real-world scenarios, and follow a personalized growth path 
                tailored just for you.
            </p>
            
            <div class="d-flex gap-3">
                <button class="ss-btn-primary px-5 py-3 fs-5" @onclick='() => Nav.NavigateTo("/profile-setup")'>
                    Start Your Journey <i class="bi bi-arrow-right ms-2"></i>
                </button>
            </div>
            
            <div class="row g-4 mt-5">
                <div class="col-4">
                    <div class="text-center">
                        <div class="h3 fw-bold mb-0">7+</div>
                        <div class="small text-muted">Core Skills</div>
                    </div>
                </div>
                <div class="col-4 border-start border-end">
                    <div class="text-center">
                        <div class="h3 fw-bold mb-0">AI</div>
                        <div class="small text-muted">Assessment</div>
                    </div>
                </div>
                <div class="col-4">
                    <div class="text-center">
                        <div class="h3 fw-bold mb-0">24/7</div>
                        <div class="small text-muted">AI Support</div>
                    </div>
                </div>
            </div>
        </div>
        
        <div class="col-lg-6">
            <div class="mockup-container">
                <div class="phone-frame">
                    <div class="phone-screen d-flex flex-column">
                        <div class="phone-header p-3 border-bottom d-flex align-items-center justify-content-between">
                            <i class="bi bi-list fs-4"></i>
                            <span class="fw-bold fs-6">SoftSync AI</span>
                            <i class="bi bi-person-circle fs-4"></i>
                        </div>
                        <div class="phone-content p-4 flex-grow-1">
                            <div class="ss-card mb-3 p-3 text-center border-0" style="background: var(--gradient-soft);">
                                <i class="bi bi-graph-up ss-gradient-text fs-1"></i>
                                <div class="fw-bold mt-2">Personal Roadmap</div>
                            </div>
                            <div class="chat-mockup mt-4">
                                <div class="chat-bubble chat-assistant" style="font-size: 0.8rem;">
                                    Hello! How can I help you today?
                                </div>
                                <div class="chat-bubble chat-user ms-auto" style="font-size: 0.8rem;">
                                    I want to improve my teamwork.
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="floating-badge badge-1 ss-card">
                    <i class="bi bi-check-circle-fill text-success me-2"></i> Skill Verified
                </div>
                <div class="floating-badge badge-2 ss-card">
                    <i class="bi bi-lightning-fill text-warning me-2"></i> AI Powered
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row g-4 mt-5 py-5">
    <div class="col-md-4">
        <div class="ss-card h-100 text-center">
            <div class="icon-box mb-3 mx-auto" style="background: rgba(99, 102, 241, 0.1); color: var(--primary);">
                <i class="bi bi-shield-check fs-2"></i>
            </div>
            <h4 class="fw-bold">AI Assessment</h4>
            <p class="text-muted px-2">Discover your true potential with our intelligent skill evaluation system.</p>
        </div>
    </div>
    <div class="col-md-4">
        <div class="ss-card h-100 text-center">
            <div class="icon-box mb-3 mx-auto" style="background: rgba(168, 85, 247, 0.1); color: var(--secondary);">
                <i class="bi bi-map fs-2"></i>
            </div>
            <h4 class="fw-bold">Personalized Roadmap</h4>
            <p class="text-muted px-2">A step-by-step learning journey customized to your strengths and goals.</p>
        </div>
    </div>
    <div class="col-md-4">
        <div class="ss-card h-100 text-center">
            <div class="icon-box mb-3 mx-auto" style="background: rgba(236, 72, 153, 0.1); color: var(--accent);">
                <i class="bi bi-chat-heart fs-2"></i>
            </div>
            <h4 class="fw-bold">AI Assistant</h4>
            <p class="text-muted px-2">Get instant feedback and guidance from your always-available AI mentor.</p>
        </div>
    </div>
</div>

<style>
    .logo-container {
        width: 64px;
        height: 64px;
        background: var(--gradient);
        border-radius: 18px;
        display: flex;
        align-items: center;
        justify-content: center;
        box-shadow: var(--shadow-card);
    }
    
    .mockup-container {
        position: relative;
        perspective: 1000px;
    }
    
    .phone-frame {
        width: 300px;
        height: 600px;
        background: #1e293b;
        border-radius: 40px;
        padding: 12px;
        box-shadow: 0 50px 100px -20px rgba(50,50,93,0.25), 0 30px 60px -30px rgba(0,0,0,0.3);
        margin: 0 auto;
        transform: rotateY(-10deg) rotateX(5deg);
    }
    
    .phone-screen {
        width: 100%;
        height: 100%;
        background: white;
        border-radius: 30px;
        overflow: hidden;
    }
    
    .icon-box {
        width: 70px;
        height: 70px;
        border-radius: 20px;
        display: flex;
        align-items: center;
        justify-content: center;
    }
    
    .floating-badge {
        position: absolute;
        padding: 1rem;
        display: flex;
        align-items: center;
        font-weight: bold;
        z-index: 10;
        white-space: nowrap;
    }
    
    .badge-1 { top: 20%; right: -10%; }
    .badge-2 { bottom: 30%; left: -5%; }
</style>
