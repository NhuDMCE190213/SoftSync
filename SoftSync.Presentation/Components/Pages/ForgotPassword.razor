@page "/forgot-password"

<PageTitle>Quên mật khẩu - SoftSync</PageTitle>

<div class="container" style="max-width:420px;margin-top:60px">
    <h3 class="mb-3 text-center">Quên mật khẩu</h3>
    <p class="text-muted text-center">Nhập email đã đăng ký, chúng tôi sẽ gửi liên kết đặt lại mật khẩu cho bạn.</p>

    @if (!string.IsNullOrEmpty(Message))
    {
        <div class="alert alert-info">@Message</div>
    }

    <form method="post" action="/api/auth/forgot-password">
        <div class="mb-3">
            <label class="form-label">Email</label>
            <input type="email" name="Email" class="form-control" required />
        </div>
        <button type="submit" class="btn btn-primary w-100">Gửi liên kết đặt lại mật khẩu</button>
    </form>

    <div class="text-center mt-3">
        <a href="/login">Quay lại đăng nhập</a>
    </div>
</div>

@code {
    [SupplyParameterFromQuery(Name = "message")]
    public string? Message { get; set; }
}