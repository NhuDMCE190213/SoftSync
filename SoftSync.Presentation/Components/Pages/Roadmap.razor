@page "/roadmap"
@page "/roadmap/{UserId:int}"
@rendermode InteractiveServer
@inherits LocalizedComponentBase
@using SoftSync.BLL.Interfaces
@using SoftSync.Common.Dtos
@inject IRoadmapService RoadmapService
@inject NavigationManager Nav

<div class="max-800 mx-auto">
    <StepIndicator CurrentStep="5" />

    <div class="tw:flex tw:justify-between tw:items-end tw:mb-6">
        <div>
            <h2 class="tw:font-bold tw:mb-1">@L["roadmap.title.prefix"] <span class="ss-gradient-text">@L["roadmap.title.highlight"]</span></h2>
            <p class="text-muted tw:mb-0">@L["roadmap.subtitle"]</p>
        </div>
        <div class="tw:text-end">
            <span class="badge bg-primary tw:text-base">@L["roadmap.demoMode"]</span>
        </div>
    </div>

    @if (roadmap == null)
    {
        <div class="tw:text-center tw:py-12">@L["roadmap.loading"]</div>
    }
    else
    {
        @foreach (var section in GetSections())
        {
            <div class="tw:mb-12">
                <div class="tw:flex tw:items-center tw:justify-between tw:mb-4">
                    <div>
                        <h4 class="tw:font-bold tw:mb-1">@section.Title</h4>
                        <p class="text-muted tw:mb-0">3 @L["roadmap.week"]</p>
                    </div>
                </div>

                <div class="tw:grid tw:grid-cols-1 tw:md:grid-cols-3 tw:gap-4">
                    @foreach (var item in section.Items)
                    {
                        <button class="ss-card ss-glass-interactive roadmap-week-card tw:p-5 tw:text-start"
                                @onclick="() => OpenLecture(item)">
                            <div class="tw:flex tw:justify-between tw:items-start tw:mb-2">
                                <div>
                                    <span class="text-primary tw:font-bold tw:text-sm tw:uppercase">@L["roadmap.week"] @item.WeekNumber</span>
                                    <h5 class="tw:font-bold tw:mt-1 tw:mb-0">@item.Title</h5>
                                </div>
                                <i class="bi bi-play-circle-fill roadmap-week-icon"></i>
                            </div>
                            <p class="text-muted tw:mb-0">@item.Description</p>
                        </button>
                    }
                </div>
            </div>
        }
    }
</div>

@code {
    [Parameter] public int UserId { get; set; }
    [Inject] private AuthenticationStateProvider AuthProvider { get; set; } = default!;
    private RoadmapDto? roadmap;

    protected override async Task OnInitializedAsync()
    {
        if (UserId == 0) UserId = await AuthProvider.GetUserIdAsync();
        roadmap = await RoadmapService.GetUserRoadmapAsync(UserId);
    }

    private IEnumerable<RoadmapSection> GetSections()
    {
        if (roadmap?.Items == null || roadmap.Items.Count == 0)
            return Enumerable.Empty<RoadmapSection>();

        return roadmap.Items
            .GroupBy(item => string.IsNullOrWhiteSpace(item.SkillName) ? L["roadmap.general"] : item.SkillName)
            .Select(group => new RoadmapSection(
                group.Key,
                group.Min(item => item.Id),
                group.OrderBy(item => item.WeekNumber).ThenBy(item => item.Id).ToList()))
            .OrderBy(section => section.Order);
    }

    private void OpenLecture(RoadmapItemDto item) =>
        Nav.NavigateTo($"/roadmap/lecture/{UserId}/{item.Id}");

    private sealed record RoadmapSection(string Title, int Order, List<RoadmapItemDto> Items);
}

<style>
    .max-800 { max-width: 800px; }
    .roadmap-week-card {
        border: 0;
        border-radius: 20px;
        transition: transform 0.18s ease, box-shadow 0.18s ease;
    }
    .roadmap-week-card:hover {
        transform: translateY(-2px);
        box-shadow: 0 20px 40px rgba(15, 23, 42, 0.12);
    }
    .roadmap-week-icon {
        font-size: 1.5rem;
        color: var(--primary);
    }
</style>
