@page "/roadmap"
@using SoftSync.BLL.Interfaces
@using SoftSync.Common.Dtos
@using SoftSync.Common.Dtos.Roadmap
@using SoftSync.Presentation.Infrastructure
@inject IRoadmapService RoadmapService
@inject NavigationManager Nav
@inject CurrentUserAccessor CurrentUserAccessor

@attribute [Authorize]

<div class="max-800 mx-auto">
    <StepIndicator CurrentStep="5" />

    <div class="d-flex justify-content-between align-items-end mb-4">
        <div>
            <h2 class="fw-bold mb-1">Lộ trình <span class="ss-gradient-text">Học tập</span> Hàng tuần</h2>
            <p class="text-muted mb-0">Theo dõi tiến độ học tập của bạn qua các kỹ năng mục tiêu.</p>
        </div>
        <div class="text-center mt-4">
            <button class="btn btn-outline-primary" @onclick='() => Nav.NavigateTo($"/select-skills/{userId}")'>
                <i class="bi bi-plus-circle me-1"></i> Học thêm kỹ năng khác
            </button>
        </div>
    </div>

    @if (roadmap == null)
    {
        <div class="text-center py-5">Đang tải lộ trình cá nhân của bạn...</div>
    }
    else
    {
        <div class="ss-roadmap-line mt-5">
            @foreach (var item in roadmap.Items)
            {
                <div class="mb-5 position-relative">
                    <div class='ss-roadmap-dot @(item.IsCompleted ? "active" : "")' style="top: 0.5rem; @(item.IsCompleted ? "" : "background: #cbd5e1;")"></div>
                    <div class="ss-card p-4 ms-2">
                        <div class="d-flex justify-content-between align-items-start mb-2">
                            <div>
                                <span class="text-primary fw-bold small text-uppercase">Tuần @item.WeekNumber</span>
                                <h5 class="fw-bold mt-1">@item.Title</h5>
                            </div>
                            <div>
                                @if (item.IsCompleted)
                                {
                                    <span class="badge bg-success"><i class="bi bi-check-circle-fill"></i> Đã hoàn thành</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Chưa hoàn thành</span>
                                }
                            </div>
                        </div>
                        <p class="text-muted mb-0">@item.Description</p>

                        @if (item.SkillId.HasValue)
                        {
                            <button class="ss-btn-primary btn-sm mt-2" disabled="@item.IsLocked"
                                    @onclick='() => Nav.NavigateTo($"/skill/{item.SkillId}/theory")'>
                                @(item.IsLocked ? "Đã khoá - hoàn thành tuần trước" : "Bắt đầu học")
                            </button>
                            <button class="btn btn-outline-primary btn-sm mt-2 ms-2" disabled="@item.IsLocked"
                                    @onclick='() => Nav.NavigateTo($"/case-studies/{item.SkillId}")'>
                                Case study
                            </button>
                        }
                        else if (!item.IsCompleted)
                        {
                            <button class="btn btn-outline-secondary btn-sm mt-2" disabled="@item.IsLocked"
                                    @onclick="() => ToggleComplete(item)">
                                Đánh dấu hoàn thành <i class="bi bi-check-lg ms-1"></i>
                            </button>
                        }
                    </div>
                </div>
            }
        </div>
    }
</div>

@code {
    private int? userId;
    private RoadmapDto? roadmap;

    protected override async Task OnInitializedAsync()
    {
        userId = await CurrentUserAccessor.GetUserIdAsync();
        if (userId.HasValue)
        {
            roadmap = await RoadmapService.GetUserRoadmapAsync(userId.Value);
        }
    }

    private async Task ToggleComplete(RoadmapItemDto item)
    {
        if (!item.IsCompleted)
        {
            await RoadmapService.MarkCompleteAsync(item.Id);
            item.IsCompleted = true;
        }
    }
}

<style>
    .max-800 { max-width: 800px; }
    .cursor-pointer { cursor: pointer; }
</style>