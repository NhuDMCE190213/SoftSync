@page "/select-skills/{UserId:int}"
@using SoftSync.BLL.Interfaces
@using SoftSync.Common.Dtos
@inject ISkillService SkillService
@inject IUserService UserService
@inject NavigationManager Nav

<div class="max-800 mx-auto">
    <StepIndicator CurrentStep="2" />

    <div class="text-center mb-5">
        <h2 class="fw-bold">Which skills do you want to improve?</h2>
        <p class="text-muted">Select as many as you'd like. Our AI will focus on these.</p>
    </div>

    <div class="row g-4 mb-5">
        @if (skills == null)
        {
            <div class="col-12 text-center">Loading skills...</div>
        }
        else
        {
            @foreach (var skill in skills)
            {
                <div class="col-md-4 col-sm-6">
                    <div class="ss-card p-4 text-center h-100 cursor-pointer @(selectedSkillIds.Contains(skill.Id) ? "selected" : "")" 
                         @onclick="() => ToggleSkill(skill.Id)">
                        <div class="skill-icon mb-3">
                            <i class="bi @skill.IconName fs-3"></i>
                        </div>
                        <h5 class="fw-bold">@skill.Name</h5>
                        <p class="small text-muted mb-0">@skill.Description</p>
                    </div>
                </div>
            }
        }
    </div>

    <div class="text-center">
        <button class="ss-btn-primary px-5 py-3 fs-5" @onclick="HandleSubmit" disabled="@(!selectedSkillIds.Any())">
            Start Assessment <i class="bi bi-arrow-right ms-2"></i>
        </button>
    </div>
</div>

@code {
    [Parameter] public int UserId { get; set; }
    private IEnumerable<SkillDto>? skills;
    private List<int> selectedSkillIds = new();

    protected override async Task OnInitializedAsync()
    {
        skills = await SkillService.GetAllSkillsAsync();
    }

    private void ToggleSkill(int id)
    {
        if (selectedSkillIds.Contains(id))
            selectedSkillIds.Remove(id);
        else
            selectedSkillIds.Add(id);
    }

    private async Task HandleSubmit()
    {
        await UserService.AddSkillSelectionsAsync(UserId, selectedSkillIds);
        Nav.NavigateTo($"/assessment/{UserId}");
    }
}

<style>
    .max-800 { max-width: 800px; }
    .cursor-pointer { cursor: pointer; }
    .ss-card.selected {
        border: 2px solid var(--primary);
        background: var(--gradient-soft);
    }
    .skill-icon {
        width: 60px;
        height: 60px;
        margin: 0 auto;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 12px;
        background: #f1f5f9;
        color: var(--primary);
    }
    .ss-card.selected .skill-icon {
        background: var(--gradient);
        color: white;
    }
</style>
