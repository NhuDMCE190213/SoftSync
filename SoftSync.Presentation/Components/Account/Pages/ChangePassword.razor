@page "/Account/ChangePassword"
@layout AccountLayout
@using System.ComponentModel.DataAnnotations
@using Microsoft.AspNetCore.Identity
@using SoftSync.DAL.Entities
@inject UserManager<ApplicationUser> UserManager
@inject SignInManager<ApplicationUser> SignInManager
@inject IdentityUserAccessor UserAccessor
@inject IdentityRedirectManager RedirectManager
@inject ILogger<ChangePassword> Logger
@inject LocalizationService L

@attribute [Microsoft.AspNetCore.Authorization.Authorize]

<PageTitle>@L["settings.password.title"]</PageTitle>

<h2 class="tw:font-bold tw:mb-2 tw:text-center">@L["settings.password.title"]</h2>
<p class="text-muted tw:text-center tw:mb-6">
    @(hasPassword ? L["settings.password.subtitle"] : L["settings.password.setSubtitle"])
</p>

<StatusMessage Message="@message" />

<EditForm Model="Input" method="post" OnValidSubmit="OnValidSubmitAsync" FormName="change-password">
    <DataAnnotationsValidator />
    <ValidationSummary class="text-danger tw:mb-3" role="alert" />

    @if (hasPassword)
    {
        <div class="tw:mb-3">
            <label class="form-label tw:font-medium">@L["settings.password.current"]</label>
            <InputText type="password" @bind-Value="Input.OldPassword" class="form-control form-control-lg" autocomplete="current-password" />
            <ValidationMessage For="() => Input.OldPassword" class="text-danger" />
        </div>
    }
    <div class="tw:mb-3">
        <label class="form-label tw:font-medium">@L["settings.password.new"]</label>
        <InputText type="password" @bind-Value="Input.NewPassword" class="form-control form-control-lg" autocomplete="new-password" />
        <ValidationMessage For="() => Input.NewPassword" class="text-danger" />
    </div>
    <div class="tw:mb-4">
        <label class="form-label tw:font-medium">@L["settings.password.confirm"]</label>
        <InputText type="password" @bind-Value="Input.ConfirmPassword" class="form-control form-control-lg" autocomplete="new-password" />
        <ValidationMessage For="() => Input.ConfirmPassword" class="text-danger" />
    </div>

    <button type="submit" class="ss-btn-primary tw:w-full tw:py-3 tw:text-lg">@L["settings.password.submit"]</button>
</EditForm>

<div class="tw:text-center tw:mt-4 tw:text-sm">
    <a href="settings">@L["settings.back"]</a>
</div>

@code {
    private string? message;
    private bool hasPassword;
    private ApplicationUser user = default!;

    [CascadingParameter] private HttpContext HttpContext { get; set; } = default!;
    [SupplyParameterFromForm] private InputModel Input { get; set; } = new();

    protected override async Task OnInitializedAsync()
    {
        user = await UserAccessor.GetRequiredUserAsync(HttpContext);
        hasPassword = await UserManager.HasPasswordAsync(user);
    }

    private async Task OnValidSubmitAsync()
    {
        IdentityResult result;
        if (hasPassword)
        {
            result = await UserManager.ChangePasswordAsync(user, Input.OldPassword ?? "", Input.NewPassword);
        }
        else
        {
            // Google-provisioned account setting a local password for the first time.
            result = await UserManager.AddPasswordAsync(user, Input.NewPassword);
        }

        if (!result.Succeeded)
        {
            message = "Error: " + string.Join(" ", result.Errors.Select(e => e.Description));
            return;
        }

        await SignInManager.RefreshSignInAsync(user);
        Logger.LogInformation("User changed their password successfully.");
        RedirectManager.RedirectToWithStatus("settings", L["settings.password.changed"], HttpContext);
    }

    private sealed class InputModel
    {
        [DataType(DataType.Password)]
        public string? OldPassword { get; set; }

        [Required(ErrorMessage = "Vui lòng nhập mật khẩu mới.")]
        [StringLength(100, ErrorMessage = "Mật khẩu phải từ {2} đến {1} ký tự.", MinimumLength = 6)]
        [DataType(DataType.Password)]
        public string NewPassword { get; set; } = "";

        [DataType(DataType.Password)]
        [Compare(nameof(NewPassword), ErrorMessage = "Mật khẩu nhập lại không khớp.")]
        public string ConfirmPassword { get; set; } = "";
    }
}
